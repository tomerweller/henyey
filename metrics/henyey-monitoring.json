{
  "uid": "henyey-monitoring",
  "title": "Henyey Monitoring (10603 Equivalent)",
  "description": "Henyey equivalent of the community Stellar Core Monitoring dashboard (Grafana 10603). Covers Critical, Quorum, Buckets, Overlay sections. App/Crypto panels omitted (see row notes).",
  "tags": [
    "henyey",
    "monitoring",
    "stellar"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "000000001"
        },
        "query": "label_values(up{job=\"henyey\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Critical",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Node Reachability",
      "description": "Whether the Henyey node is up and reachable by Prometheus.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "up{job=\"henyey\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Ledger Age",
      "description": "Seconds since last ledger close. Equivalent to stellar-core panel 'Ledger age'.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "stellar_ledger_age_current_seconds{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 30,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Ledger Age (5m avg)",
      "description": "5-minute average of ledger age.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "avg_over_time(stellar_ledger_age_current_seconds{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}} 5m avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Quorum Fail At",
      "description": "Number of peers that can fail before quorum is lost. Equivalent to stellar-core 'Quorum fail at'.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "stellar_quorum_fail_at{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 2,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Node Sync Status",
      "description": "Whether the node is in sync (herder state == 2 means Tracking/Synced). Equivalent to stellar-core 'synced' panel.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "stellar_herder_state{instance=~\"$instance\"} == bool 2",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OUT OF SYNC",
                  "color": "red"
                },
                "1": {
                  "text": "SYNCED",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Quorum",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 200,
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Quorum Missing Peers",
      "description": "Count of quorum set nodes not responding. Equivalent to stellar-core 'Quorum missing'.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "stellar_quorum_missing{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 3,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Quorum Delayed Peers",
      "description": "Count of quorum set nodes lagging behind the local node (subset of agree). New metric added for dashboard parity.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "stellar_quorum_delayed{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 3,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Quorum Agree / Disagree",
      "description": "Count of quorum set nodes agreeing and disagreeing.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "stellar_quorum_agree{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} agree"
        },
        {
          "expr": "stellar_quorum_disagree{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} disagree"
        }
      ]
    },
    {
      "type": "row",
      "title": "Buckets",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 300,
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Bucket Add Time",
      "description": "Bucket list addition time per ledger close. Adapted from stellar-core 'Bucket batch addtime'. Uses histogram rate(sum)/rate(count).",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "rate(henyey_ledger_close_bucket_add_seconds_sum{instance=~\"$instance\"}[5m]) / rate(henyey_ledger_close_bucket_add_seconds_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}} avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Bucket Merge Objects",
      "description": "Objects produced by bucket merges. Adapted from stellar-core 'Bucket batch objects added' using merge output counters.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "rate(stellar_bucket_merge_new_live_total{instance=~\"$instance\"}[5m]) + rate(stellar_bucket_merge_new_dead_total{instance=~\"$instance\"}[5m]) + rate(stellar_bucket_merge_new_init_total{instance=~\"$instance\"}[5m]) + rate(stellar_bucket_merge_new_meta_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}} objects/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "row",
      "title": "Overlay",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 400,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Overlay Timeout Idle",
      "description": "Idle peer timeouts. Direct match to stellar-core 'Overlay timeout idle'.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 25
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "rate(stellar_overlay_timeout_idle_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Overlay Timeout Straggler",
      "description": "Straggler peer timeouts. Direct match to stellar-core 'Overlay timeout straggler'.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 25
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "rate(stellar_overlay_timeout_straggler_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Overlay Connections Pending",
      "description": "Pending overlay connections (inbound + outbound). Adapted from stellar-core 'Overlay connection pending'.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 25
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "stellar_overlay_inbound_pending{instance=~\"$instance\"} + stellar_overlay_outbound_pending{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} total"
        },
        {
          "expr": "stellar_overlay_inbound_pending{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} inbound"
        },
        {
          "expr": "stellar_overlay_outbound_pending{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} outbound"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Overlay Connections Authenticated",
      "description": "Authenticated overlay connections (inbound + outbound). Adapted from stellar-core 'Overlay connection authenticated'.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 25
      },
      "datasource": {
        "type": "prometheus",
        "uid": "000000001"
      },
      "targets": [
        {
          "expr": "stellar_overlay_inbound_authenticated{instance=~\"$instance\"} + stellar_overlay_outbound_authenticated{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} total"
        },
        {
          "expr": "stellar_overlay_inbound_authenticated{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} inbound"
        },
        {
          "expr": "stellar_overlay_outbound_authenticated{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} outbound"
        }
      ]
    },
    {
      "type": "row",
      "title": "App (Not Applicable)",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 500,
      "panels": [
        {
          "id": 15,
          "type": "text",
          "title": "App Metrics \u2014 Intentionally Absent",
          "gridPos": {
            "h": 3,
            "w": 24,
            "x": 0,
            "y": 32
          },
          "options": {
            "mode": "markdown",
            "content": "Stellar-core's `app.post-on-{main,background}-thread.delay` metrics track queue-backed thread model delays. Henyey uses a tokio async runtime and has no equivalent concept. Tokio runtime metrics (`tokio_runtime_*`) could be added in a future panel."
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Crypto (Not Applicable)",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 600,
      "panels": [
        {
          "id": 16,
          "type": "text",
          "title": "Crypto Metrics \u2014 Intentionally Absent",
          "gridPos": {
            "h": 3,
            "w": 24,
            "x": 0,
            "y": 33
          },
          "options": {
            "mode": "markdown",
            "content": "Stellar-core's `crypto.verify.hit` / `_total` tracks a signature verification cache hit rate. Henyey has no signature cache; verification is handled by the SCP verify pipeline (`henyey_scp_verify_*` metrics). A cache could be added in the future."
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
